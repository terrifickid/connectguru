# Contentful Configuration
# These are required for the in-app contact form handler (/api/contact)
# which saves submissions directly to Contentful.

# Your Contentful Space ID (found in Settings > General)
CONTENTFUL_SPACE_ID=

# Content Management API (CMA) token with read + write + publish permissions.
# Create one at: Settings > API keys > Content management tokens
# DO NOT use a Delivery or Preview token here.
CONTENTFUL_MANAGEMENT_TOKEN=

# Contentful Environment ID (optional, defaults to "master")
CONTENTFUL_ENVIRONMENT=master

# Content Type ID for form submissions (optional, defaults to "actaiApplication")
# You must have this content type in your space (see fields below).
CONTENTFUL_CONTACT_CONTENT_TYPE=actaiApplication

# === Required Content Type Fields (create in Contentful UI) ===
# API identifier must match CONTENTFUL_CONTACT_CONTENT_TYPE (default: actaiApplication)
# Recommended field types:
#   title                 : Short text  (make this the "Display field")
#   firstName             : Short text
#   lastName              : Short text
#   email                 : Short text
#   contactNumber         : Short text
#   socialMediaHandles    : Short text
#   nameOfCompany         : Short text
#   phaseOfProject        : Short text
#   aboutYourProject      : Long text   (recommended for longer descriptions)
#   website               : Short text
#   submittedAt           : Date and time
#
# After creating the content type, click "Save" then "Publish" the content type.

# === Structured Logging / Telemetry (pino, modeled after glits) ===
# LOG_LEVEL=info|debug|error   (default: info)
# SERVICE_NAME=connectguru-contact
# SERVICE_VERSION=0.1.0
#
# All submissions emit rich structured JSON logs with phases, ERROR_TYPE/LOG_TYPE,
# child logger context (functionName, phases), and serialized errors.
# This gives full telemetry across: receive → parse → Contentful init → create → publish.
# Vercel captures the JSON; set LOG_LEVEL=debug for extra detail in non-prod.
